# Trading Agent V2 — environment vars
# Copy to .env and fill in. Never commit .env.

# --- V2's Alpaca paper account (DIFFERENT FROM V1) ---
V2_ALPACA_API_KEY=
V2_ALPACA_SECRET_KEY=
V2_ALPACA_BASE_URL=https://paper-api.alpaca.markets

# --- V1's Alpaca paper account (read-only mirror, optional) ---
# Used when side_by_side_runner reads V1's ledger from this machine
# instead of polling the Hetzner server.
V1_ALPACA_API_KEY=
V1_ALPACA_SECRET_KEY=
V1_ALPACA_BASE_URL=https://paper-api.alpaca.markets

# --- V1 mirror path ---
# Where V1 lives locally; comparison_ledger reads V1's trade_log from here.
V1_REPO_PATH=C:\Projects\tradingap
V1_TRADE_LOG=C:\Projects\tradingap\trade_log.jsonl
V1_LEDGER=C:\Projects\tradingap\executioner_ledger.json
V1_SEMANTIC_MEMORY_DB=C:\Projects\tradingap\semantic_memory.db

# --- LLM keys (same vendors as V1's council) ---
ANTHROPIC_API_KEY=
GROQ_API_KEY=
GEMINI_API_KEY=
XAI_API_KEY=

# --- V2 model selection ---
V2_BASE_MODEL=Qwen/Qwen2.5-7B-Instruct
V2_JUDGE_MODEL=claude-opus-4-6
V2_PERSONA_MODEL=claude-haiku-4-5-20251001

# --- V2 retrieval ---
V2_FAISS_INDEX=memory_v2/indexes/dense.faiss
V2_BM25_INDEX=memory_v2/indexes/bm25.pkl
V2_EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# --- V2 evolution ---
V2_POPULATION_SIZE=8
V2_GENERATION_BUDGET_USD=5.00
V2_FITNESS_LAMBDA=0.0          # 0.0 = pure V1 mirror in gen 0
